# Copy this file to `.env` and fill in the values below before running
# `aio app build` / `aio app deploy`. Do not commit the resulting `.env`.

# Logging level for all runtime actions. One of: debug, info, warn, error.
LOG_LEVEL=info

# Symmetric key used to encrypt secrets/credentials before they are persisted in the app's
# business configuration (commerce/configuration/1 extension). Generate a random 32+ character
# value and keep it secret; rotating it invalidates previously stored encrypted config.
AIO_COMMERCE_CONFIG_ENCRYPTION_KEY=
