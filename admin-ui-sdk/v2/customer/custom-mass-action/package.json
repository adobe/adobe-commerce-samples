    "@adobe/react-spectrum": "^3.30.0",
    "@adobe/uix-core": "^0.8.3",
    "@adobe/uix-guest": "^0.8.3",
    "@react-spectrum/s2": "^1.5.1",
    "@spectrum-icons/workflow": "^4.2.4",
    "cloudevents": "^6.0.3",
    "core-js": "^3.27.2",
    "crypto": "^1.0.1",
    "crypto-browserify": "^3.12.0",
    "got": "^11.8.5",
    "https-browserify": "^1.0.0",
    "node-fetch": "^3.3.0",
    "oauth-1.0a": "^2.2.6",
    "os-browserify": "^0.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-error-boundary": "^3.1.4",
